generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String             @id @default(cuid())
  name               String?
  email              String?            @unique
  emailVerified      DateTime?
  image              String?
  password           String?
  customBadge        String?
  role               UserRole           @default(MEMBER)
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  subscriptionPlan   String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  purchasedServices  String[]
  accounts           Account[]
  posts              Post[]
  savedArticles      SavedArticle[]
  sessions           Session[]
  predictions        Prediction[]
  comments           Comment[]
  analystScore       AnalystScore?
  // Enhanced CMS relations
  media              Media[]            @relation("UserMedia")
  blockTemplates     BlockTemplate[]    @relation("UserTemplates")
  pages              Page[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedArticle {
  id      String   @id @default(cuid())
  userId  String
  slug    String
  type    String
  savedAt DateTime @default(now())
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, slug, type])
}

model Post {
  id              String      @id @default(cuid())
  title           String
  slug            String      @unique
  excerpt         String?
  content         String
  type            ArticleType @default(RESEARCH)
  published       Boolean     @default(false)
  featuredImage   String?
  authorId        String
  seoTitle        String?
  metaDescription String?
  focusKeywords   String?
  ogImage         String?
  ogTitle         String?
  tags            String[]    @default([])
  difficulty      String      @default("INTERMEDIATE")
  targetAudience  String[]    @default([])
  contentStatus   String      @default("DRAFT") // DRAFT, REVIEW, APPROVED, PUBLISHED
  estimatedReadingTime Int      @default(5)
  scheduledPublishAt DateTime?
  viewCount       Int         @default(0)
  publishedAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  author          User        @relation(fields: [authorId], references: [id])
  comments        Comment[]
  // Enhanced CMS fields
  blockContent    Json?       // Alternative to markdown content for block-based editing
  contentType     String      @default("MARKDOWN") // MARKDOWN or BLOCKS
  media           Media[]     @relation("PostMedia")
  blocks          ContentBlock[] @relation("PostBlocks")

  @@index([type])
  @@index([published])
  @@index([slug])
}

// ─── ENHANCED CMS MODELS ──────────────────────────────────────────────────────

model Media {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  path        String   // Relative path from public/uploads
  url         String   // Full URL
  mimeType    String
  size        Int      // Bytes
  width       Int?
  height      Int?
  altText     String?
  caption     String?
  description String?
  uploadedBy  String   // User ID
  uploadedAt  DateTime @default(now())
  metadata    Json?    // EXIF data, etc.
  
  // Relationships
  user        User     @relation("UserMedia", fields: [uploadedBy], references: [id])
  posts       Post[]   @relation("PostMedia")
  
  @@index([uploadedAt])
  @@index([mimeType])
  @@index([uploadedBy])
}

model ContentBlock {
  id          String   @id @default(cuid())
  type        String   // paragraph, heading, image, columns, etc.
  data        Json     // Block-specific data
  attributes  Json?    // Style attributes
  order       Int      // Position in parent
  parentId    String?  // For nested blocks
  postId      String?  // If attached to a post
  pageId      String?  // If attached to a page
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relationships
  post        Post?    @relation("PostBlocks", fields: [postId], references: [id])
  page        Page?    @relation("PageBlocks", fields: [pageId], references: [id])
  parent      ContentBlock? @relation("BlockParent", fields: [parentId], references: [id])
  children    ContentBlock[] @relation("BlockParent")
  
  @@index([postId])
  @@index([pageId])
  @@index([parentId])
  @@index([type])
  @@index([order])
}

model BlockTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // section, component, layout
  preview     String?  // Preview image URL
  data        Json     // Block data structure
  category    String   // hero, feature, cta, etc.
  isPublic    Boolean  @default(true)
  createdBy   String   // User ID
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relationships
  user        User     @relation("UserTemplates", fields: [createdBy], references: [id])
  
  @@index([category])
  @@index([type])
  @@index([isPublic])
  @@index([createdBy])
}

model Page {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     Json?    // Block-based content
  htmlContent String?  // Rendered HTML (cached)
  status      PageStatus @default(DRAFT)
  seoTitle    String?
  metaDescription String?
  featuredImage String?
  authorId    String
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relationships
  author      User     @relation(fields: [authorId], references: [id])
  blocks      ContentBlock[] @relation("PageBlocks")
  
  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([publishedAt])
}

enum PageStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

model PageView {
  id         String   @id @default(cuid())
  path       String
  userId     String?
  sessionId  String
  durationMs Int      @default(0)
  referrer   String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([path])
  @@index([userId])
  @@index([sessionId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([sessionId, path]) // Composite index for upsert queries
}

model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  provider  String   @default("credentials")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([provider]) // For groupBy queries on provider
}

model FeaturedContent {
  id        String   @id
  section   String
  contentId String
  order     Int
  updatedAt DateTime
  createdAt DateTime @default(now())

  @@unique([section, contentId])
  @@index([section, order])
}

model HomePageAuditLog {
  id        String   @id
  action    String
  section   String?
  itemId    String?
  userId    String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([section])
  @@index([userId])
}

model HomePageConfig {
  id        String          @id
  section   HomePageSection @unique
  config    Json
  enabled   Boolean         @default(true)
  order     Int
  updatedAt DateTime
  createdAt DateTime        @default(now())

  @@index([enabled])
  @@index([order])
  @@index([section])
}

model HomePageItem {
  id          String   @id
  section     String
  title       String
  subtitle    String?
  description String?
  icon        String?
  link        String?
  color       String?
  order       Int
  enabled     Boolean  @default(true)
  updatedAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([section, order])
  @@index([section, enabled])
  @@index([section])
  @@index([section, order])
}

enum UserRole {
  MEMBER
  VIEWER
  ADMIN
  ANALYST
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum ArticleType {
  RESEARCH
  INSIGHT
  CASE_STUDY
  MEDIA
  OTHER
}

enum HomePageSection {
  RESEARCH
  INSIGHTS
  PILLARS
  TRACKERS
  PODCAST
  HERO_STATS
}

// ─── ANALYST CALIBRATION SCORE ────────────────────────────────────────────────

enum PredictionStatus {
  PENDING
  CONFIRMED
  INCORRECT
  PARTIAL
}

model Prediction {
  id             String           @id @default(cuid())
  slug           String           @unique
  authorId       String
  author         User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  claim          String           // The prediction text
  sector         String
  resolveDate    DateTime
  status         PredictionStatus @default(PENDING)
  resolutionNote String?
  reportSlug     String?          // Which post/report it came from
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  comments       Comment[]

  @@index([authorId])
  @@index([status])
  @@index([sector])
  @@index([resolveDate])
}

model AnalystScore {
  id               String   @id @default(cuid())
  authorId         String   @unique
  author           User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  totalPredictions Int      @default(0)
  confirmed        Int      @default(0)
  incorrect        Int      @default(0)
  partial          Int      @default(0)
  calibrationScore Float    @default(0)
  longestStreak    Int      @default(0)
  lastCalculated   DateTime @default(now())

  @@index([authorId])
  @@index([calibrationScore])
}

// ─── COMMENTS & COMMUNITY ──────────────────────────────────────────────────────

model Comment {
  id           String      @id @default(cuid())
  content      String
  authorId     String
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId       String?
  post         Post?       @relation(fields: [postId], references: [id], onDelete: Cascade)
  predictionId String?
  prediction   Prediction? @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([authorId])
  @@index([postId])
  @@index([predictionId])
  @@index([createdAt])
}
